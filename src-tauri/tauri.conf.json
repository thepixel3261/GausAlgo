{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/tauri-v2/crates/tauri-cli/schema.json",
  "productName": "Gauß-Algorithmus Löser",
  "version": "0.1.0",
  "identifier": "com.gausalgo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "trunk serve --port 1420",
    "beforeBuildCommand": "trunk build"
  },
  "app": {
    "windows": [
      {
        "title": "Gauß-Algorithmus Löser",
        "width": 960,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
